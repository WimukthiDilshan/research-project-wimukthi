APP_NAME=Explainable AI Module Backend
APP_VERSION=0.1.0
API_PREFIX=/api/v1
GPT_API_KEY=
GPT_MODEL=gpt-4o-mini
GPT_TIMEOUT_SECONDS=20
DB_HOST=localhost
USER=root
PASSWORD=
DB_NAME=explanable_ai
DB_PORT=3306

# ===== Explainability Microservice =====
# Your backend calls the other member's microservice here.
# That service owns the Random Forest model and returns cognitive load predictions.
# Your project computes real SHAP and LIME locally around that API prediction.
EXPLAINABILITY_MICROSERVICE_URL=http://localhost:5000
EXPLAINABILITY_MICROSERVICE_PATH=/predict
EXPLAINABILITY_MICROSERVICE_TIMEOUT_SECONDS=30
